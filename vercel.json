{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "routes": [
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/icon-192.png", "dest": "/icon-192.png" },
    { "src": "/icon-512.png", "dest": "/icon-512.png" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/store", "dest": "/store.html" },
    { "src": "/product", "dest": "/product.html" },
    { "src": "/thank-you", "dest": "/thank-you.html" },
    { "src": "/merchant-dashboard", "dest": "/merchant-dashboard.html" }
  ]
}
